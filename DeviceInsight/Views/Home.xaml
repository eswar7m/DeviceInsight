<Page x:Class="DeviceInsight.Views.Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="Home"
      Background="White">

    <DockPanel>
        <!-- Top Navigation Bar -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20">
            <TextBlock Text="DeviceInsight" FontSize="24" FontWeight="Bold" Foreground="#333333"/>
        </Border>
        <!-- Sidebar Navigation -->
        <Border DockPanel.Dock="Left" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Width="200" Padding="10">
            <StackPanel Margin="0,20,0,0">
                <Button x:Name="BatteryButton" Style="{StaticResource NavigationButton}" Click="Battery_Health_Click" Content="🔋 Battery Health"/>
                <!-- New features will be added here -->
            </StackPanel>
        </Border>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Select a feature from the sidebar to get started" FontSize="14" Foreground="#666666" TextAlignment="Center"/>
        </StackPanel>
    </DockPanel>
</Page>